---
import SidebarSection from '../components/SidebarSection.astro';
import TabContent from '../components/TabContent.astro';
import '../../src/styles/global.css';
---

<div id="gpt-right-sidebar">
  <div class="gpt-tabs">
    <button class="gpt-tab-btn active" data-target="gpt-tab-org">Organise</button>
    <button class="gpt-tab-btn" data-target="gpt-tab-tools">Tools</button>
    <button class="gpt-tab-btn" data-target="gpt-tab-set">Settings</button>
  </div>

  <TabContent id="gpt-tab-org" isActive={true}>
    <SidebarSection title="📁 Folders">
      <div class="gpt-input-group" style="display: flex; gap: 8px; margin-bottom: 10px;">
        <input type="text" id="gpt-new-folder-input" placeholder="New folder name..." style="flex: 1; padding: 8px; border-radius: 4px; border: 1px solid #334155; background: #1e293b; color: white;" />
        <button class="gpt-action-btn secondary" id="gpt-create-folder" style="padding: 8px 12px;">Add</button>
      </div>
      <div id="gpt-folder-list" style="display: flex; flex-direction: column; gap: 8px;"></div>
    </SidebarSection>

    <SidebarSection title="📦 Bulk Operations">
      <button class="gpt-action-btn secondary" id="gpt-open-bulk">Launch Bulk Manager</button>
    </SidebarSection>

    <SidebarSection title="🏷️ Custom Tags">
      <div class="gpt-input-group">
        <input type="text" id="gpt-tag-input" placeholder="e.g. #Research" />
      </div>
      <div class="gpt-colour-picker-row">
        <div class="gpt-colour-swatch selected" data-colour="#4a90e2" style="background:#4a90e2;"></div>
        <div class="gpt-colour-swatch" data-colour="#ef4444" style="background:#ef4444;"></div>
        <div class="gpt-colour-swatch" data-colour="#f97316" style="background:#f97316;"></div>
        <div class="gpt-colour-swatch" data-colour="#22c55e" style="background:#22c55e;"></div>
        <input type="color" id="gpt-custom-colour" class="gpt-custom-colour-picker" value="#4a90e2" aria-label="Select custom RGB colour" />
      </div>
      <button class="gpt-action-btn secondary" id="gpt-save-tag">Create Tag</button>
      <div id="gpt-tag-list" style="margin-top:15px;"></div>
    </SidebarSection>
  </TabContent>

  <TabContent id="gpt-tab-tools">
    <SidebarSection title="🤖 Output Settings">
      <div class="gpt-toggle-wrapper">
        <span class="gpt-toggle-label">Enable Natural Responses</span>
        <label class="gpt-switch">
          <input type="checkbox" id="gpt-natural-toggle" />
          <span class="gpt-slider"></span>
        </label>
      </div>
      <div class="gpt-input-group">
        <button class="gpt-action-btn secondary" id="gpt-open-natural-settings" style="flex: 1; font-size: 0.85em;">Customise</button>
        <select id="gpt-output-language" style="flex: 1.5; font-size: 0.85em;">
          <option value="">Default (Auto-Detect)</option>
          <option value="English (UK)">English (UK)</option>
          <option value="English (US)">English (US)</option>
          <option value="French">French</option>
          <option value="Spanish">Spanish</option>
          <option value="Chinese (Mandarin)">Chinese (Mandarin)</option>
        </select>
      </div>
    </SidebarSection>

    <SidebarSection title="✍️ Prompt Library">
      <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 15px;">
        <textarea id="gpt-prompt-input" placeholder="e.g. Translate [Text]..." class="gpt-custom-textarea"></textarea>
        <button class="gpt-action-btn secondary" id="gpt-save-prompt" style="width: 100%;">Save Prompt</button>
      </div>
      <div class="gpt-input-group">
        <select id="gpt-prompt-select"><option value="">-- Saved Prompts --</option></select>
        <button class="gpt-action-btn secondary" id="gpt-insert-prompt">Insert</button>
      </div>
      <div style="display: flex; gap: 8px;">
        <button class="gpt-action-btn secondary" id="gpt-edit-prompt" style="flex: 1; font-size: 0.8em; padding: 8px;">Edit</button>
        <button class="gpt-action-btn secondary" id="gpt-rename-prompt" style="flex: 1; font-size: 0.8em; padding: 8px;">Rename</button>
        <button class="gpt-action-btn secondary" id="gpt-delete-prompt" style="flex: 1; font-size: 0.8em; padding: 8px; color: #ef4444;">Delete</button>
      </div>
    </SidebarSection>
  </TabContent>

  <TabContent id="gpt-tab-set">
    <SidebarSection title="📄 Export Data">
      <button class="gpt-action-btn" id="gpt-export-md" style="background: #4a90e2; border: none; color: white;">Export Current Conversation</button>
    </SidebarSection>
    <SidebarSection title="💾 Cloud Sync">
      <div class="gpt-toggle-wrapper">
        <span class="gpt-toggle-label" style="font-size: 0.9em;">Auto-Sync to Google Drive</span>
        <label class="gpt-switch">
          <input type="checkbox" id="gpt-cloud-sync-toggle" />
          <span class="gpt-slider"></span>
        </label>
      </div>
      <p style="font-size: 0.82em; color: #ef4444; margin-top: 8px;">Warning: Switching this off means data will not be backed up to Drive.</p>
    </SidebarSection>
    <SidebarSection title="⏱️ Auto-Backups">
      <p style="font-size: 0.85em; color: #64748b; margin-bottom: 10px;">Automatically saves a snapshot every 10 mins.</p>
      <button class="gpt-action-btn secondary" id="gpt-open-auto-backups" style="width:100%; border: 1px solid #a855f7; color: #a855f7; background: transparent;">Launch Time Machine</button>
    </SidebarSection>
    <SidebarSection title="⚠️ Danger Zone">
      <p style="font-size: 0.85em; color: #64748b; margin-bottom: 10px;">Completely wipe all local and cloud data.</p>
      <button class="gpt-action-btn secondary" id="gpt-factory-reset" style="width:100%; border: 1px solid #ef4444; color: #ef4444; background: transparent;">Factory Reset</button>
    </SidebarSection>
  </TabContent>
</div>
