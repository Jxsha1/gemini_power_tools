{
  "manifest_version": 3,
  "name": "Gemini Workspace Tools",
  "version": "1.1",
  "description": "Organise your Gemini chats with custom folders, tags, prompt libraries, and automatic Google Drive backups.",
  "icons": {
    "128": "icon128.png"
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "oauth2": {
    "client_id": "792970609633-ubacgncaiv5e9mgtkkcn24gnp21ugc88.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "css": [
        "assets/sidebar.css"
      ],
      "js": [
        "assets/sidebarEntry.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html",
        "assets/sidebar.css"
      ],
      "matches": [
        "https://gemini.google.com/*"
      ]
    }
  ]
}
